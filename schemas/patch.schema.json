{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DOCX Patch (machine-applicable instruction set)",
  "description": "Used by `image relink ... --apply-patch <patch.json>` (ex qual-supply relink_images_from_source.py --apply-patch). Detect-phase emits patch JSON, main process applies it serially (W3/W4 concurrent safe).",
  "type": "object",
  "required": ["version", "target_docx", "instructions"],
  "properties": {
    "version": {"const": "1"},
    "target_docx": {"type": "string"},
    "source_docx": {"type": "string", "description": "patch 生成时参考的源 docx"},
    "instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "enum": [
              "embed-media",
              "update-rels",
              "update-content-types",
              "replace-blip-ref",
              "insert-paragraph",
              "delete-paragraph"
            ]
          },
          "media_part_path": {"type": "string", "description": "word/media/imageN.png"},
          "media_binary_b64": {"type": "string", "description": "base64 of media bytes"},
          "rId": {"type": "string"},
          "blip_xpath": {"type": "string"},
          "target_idx": {"type": "integer"},
          "params": {"type": "object"}
        }
      }
    }
  }
}
